{
  "name": "utility-toolvault",
  "version": "2.0.0",
  "description": "Utility ToolVault — Offline-first desktop utility toolkit with 18 tools across 6 categories.",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron . --dev\"",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development --port 3000",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId": "com.manish.utilitytoolvault",
    "productName": "Utility ToolVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "ipc-channels.js",
      "pdf-service.js",
      "pdf-renderer.js",
      "image-service.js",
      "background-remover.js",
      "data-service.js",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**"
    ],
    "extraResources": [
      {
        "from": "binaries/",
        "to": "binaries/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "bwip-js": "^4.11.1",
    "diff": "^9.0.0",
    "docx": "^9.7.1",
    "electron-rebuild": "^3.2.9",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "marked": "^5.1.2",
    "path2d-polyfill": "^3.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.32.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@electron/rebuild": "^4.0.4",
    "autoprefixer": "^10.4.17",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  }
}
